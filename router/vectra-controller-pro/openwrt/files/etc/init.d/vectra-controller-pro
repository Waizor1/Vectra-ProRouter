#!/bin/sh /etc/rc.common

START=95
STOP=20
USE_PROCD=1

CONF="vectra-controller-pro"
SECTION="main"
RENDERER="/usr/libexec/vectra-controller-pro/render-xray-config.sh"
# Rendered daemon config lives on tmpfs and is regenerated from UCI + board
# state on every boot, mirroring the vectra-controller-agent pattern. The
# binary's compiled-in default is /etc/vectra-controller-pro/agent.json, so we
# pass the rendered path explicitly with -config.
AGENT_JSON="/var/run/vectra-controller-pro/agent.json"
# GoPackage installs cmd/vctl as /usr/sbin/vctl (binary name = last path
# component of GO_PKG_BUILD_PKG). Keep this path in lockstep with the Makefile.
VCTL_BIN="/usr/sbin/vctl"

start_service() {
	local enabled
	[ "${VECTRA_SKIP_POSTINST_RESTART:-}" = "1" ] && return 0

	config_load "$CONF"
	config_get_bool enabled "$SECTION" enabled 1
	[ "$enabled" -eq 1 ] || return 0

	# Mutual exclusion: exactly one controller owns a router. If the legacy
	# vectra-controller agent is present (canary cutover, where vctl adopts the
	# same router identity), stop and disable it so the two daemons never check
	# in concurrently with the same id/token.
	if [ -x /etc/init.d/vectra-controller ]; then
		logger -t vectra-controller-pro "stopping legacy vectra-controller (xray-direct takes over)"
		/etc/init.d/vectra-controller disable >/dev/null 2>&1 || true
		/etc/init.d/vectra-controller stop >/dev/null 2>&1 || true
	fi

	[ -x "$RENDERER" ] || return 1
	[ -x "$VCTL_BIN" ] || return 1

	mkdir -p /var/run/vectra-controller-pro
	"$RENDERER" "$AGENT_JSON" || return 1

	procd_open_instance
	procd_set_param command "$VCTL_BIN" agent -config "$AGENT_JSON"
	procd_set_param respawn 15 5 20
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_set_param file /etc/config/vectra-controller-pro
	procd_close_instance
}

reload_service() {
	[ "${VECTRA_SKIP_POSTINST_RESTART:-}" = "1" ] && return 0
	stop
	start
}
