#!/bin/sh /etc/rc.common
# Procd service for vectra-oom-guard. START=99 so we come up after passwall2
# (also START=99) — if our daemon starts a few seconds before xray that's fine,
# it just no-ops for that interval and picks up xray on the next sweep.

USE_PROCD=1
START=99
STOP=01

start_service() {
	[ -x /usr/sbin/vectra-oom-guard ] || return 1
	procd_open_instance
	procd_set_param command /usr/sbin/vectra-oom-guard
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
