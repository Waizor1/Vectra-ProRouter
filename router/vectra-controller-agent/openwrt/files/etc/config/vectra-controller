config controller 'main'
	option enabled '1'
	option control_url 'https://api.vectra-pro.net'
	option panel_url 'https://router.vectra-pro.net'
	option poll_interval '45s'
	option request_timeout '10s'
	option state_path '/etc/vectra-controller/state.json'
	option status_path '/var/run/vectra-controller/status.json'
	option config_render_path '/var/run/vectra-controller/config.json'
