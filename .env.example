# Copy to ".env" on the Ubuntu 24.04 VPS before running docker compose.
# Values here are placeholders only.

COMPOSE_PROJECT_NAME=vectra
OPERATOR_DOMAIN=router.vectra-pro.net
ROUTER_API_DOMAIN=api.vectra-pro.net
ACME_EMAIL=admin@vectra-pro.net
TZ=UTC

POSTGRES_DB=vectra
POSTGRES_USER=vectra
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://vectra:change-this-postgres-password@postgres:5432/vectra

VECTRA_DEFAULT_CONTROL_DOMAIN=https://router.vectra-pro.net
VECTRA_ROUTER_API_BASE_URL=https://api.vectra-pro.net
VECTRA_OPERATOR_USER=operator
VECTRA_OPERATOR_PASSWORD=change-this-operator-password
VECTRA_SECRETS_KEY=replace-with-64-hex-characters
VECTRA_ARTIFACT_BASE_URL=https://api.vectra-pro.net/artifacts
VECTRA_POLLING_INTERVAL_SECONDS=45
VECTRA_WEB_PUSH_PUBLIC_KEY=
VECTRA_WEB_PUSH_PRIVATE_KEY=
VECTRA_WEB_PUSH_SUBJECT=mailto:admin@vectra-pro.net
VECTRA_WEB_PUSH_MONITOR_INTERVAL_SECONDS=60
NEXT_TELEMETRY_DISABLED=1

BACKUP_KEEP_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
