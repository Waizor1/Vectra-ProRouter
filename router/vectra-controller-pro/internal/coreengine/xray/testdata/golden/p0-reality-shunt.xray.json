{
  "log": {
    "loglevel": "info"
  },
  "api": {
    "tag": "api",
    "services": [
      "HandlerService",
      "StatsService",
      "ObservatoryService",
      "LoggerService"
    ]
  },
  "dns": {
    "servers": [
      {
        "address": "https://dns.google/dns-query",
        "queryStrategy": "UseIPv4"
      },
      {
        "address": "8.8.8.8",
        "skipFallback": true,
        "domains": [
          "geosite:cn"
        ],
        "queryStrategy": "UseIPv4"
      }
    ],
    "hosts": {
      "dns.google": "8.8.8.8"
    },
    "queryStrategy": "UseIPv4",
    "tag": "dns-upstream"
  },
  "stats": {},
  "inbounds": [
    {
      "tag": "tproxy-in",
      "listen": "0.0.0.0",
      "port": 12345,
      "protocol": "dokodemo-door",
      "settings": {
        "network": "tcp,udp",
        "followRedirect": true
      },
      "streamSettings": {
        "sockopt": {
          "mark": 1,
          "tproxy": "tproxy"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "dns-in",
      "listen": "127.0.0.1",
      "port": 5353,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "8.8.8.8",
        "port": 53,
        "network": "tcp,udp"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "AsIs"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {}
    },
    {
      "tag": "dns-out",
      "protocol": "dns",
      "settings": {}
    },
    {
      "tag": "node-world-de",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "de1.example.online",
            "port": 443,
            "users": [
              {
                "id": "00000000-0000-0000-0000-000000000000",
                "flow": "xtls-rprx-vision",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "firefox",
          "serverName": "www.cloudflare.com",
          "publicKey": "REPLACE_REALITY_PUBLIC_KEY",
          "shortId": "abcdef",
          "spiderX": "/"
        }
      }
    },
    {
      "tag": "node-world-pl",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "pl1.example.online",
            "port": 443,
            "users": [
              {
                "id": "00000000-0000-0000-0000-000000000000",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "serverName": "www.microsoft.com",
          "publicKey": "REPLACE_REALITY_PUBLIC_KEY",
          "shortId": "00"
        },
        "grpcSettings": {
          "serviceName": "voice"
        }
      },
      "mux": {
        "enabled": true,
        "concurrency": -1,
        "xudpConcurrency": 16,
        "packetEncoding": "xudp"
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "domainMatcher": "hybrid",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          "dns-in"
        ],
        "outboundTag": "dns-out"
      },
      {
        "type": "field",
        "inboundTag": [
          "api"
        ],
        "outboundTag": "api"
      },
      {
        "type": "field",
        "domain": [
          "geosite:cn"
        ],
        "outboundTag": "direct",
        "ruleTag": "direct-cn"
      },
      {
        "type": "field",
        "port": "19294-19344,50000-50100",
        "network": "udp",
        "outboundTag": "node-world-pl",
        "ruleTag": "discord-udp"
      },
      {
        "type": "field",
        "outboundTag": "node-world-de",
        "ruleTag": "world-proxy"
      }
    ]
  }
}